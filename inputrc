set bell-style none
"\e[1~": beginning-of-line
"\e[4~": end-of-line
"\e[1;5D": backward-word
"\e[1;5C": forward-word
"\e[1;2D": backward-char
"\e[1;2C": forward-char
"\e[1;6D": backward-char
"\e[1;6C": forward-char
"\e\e[D": backward-char
"\e\e[C": forward-char

"\eOc":forward-word
"\eOd":backward-word
"\e\eOc":forward-word
"\e\eOd":backward-word
